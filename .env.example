# ── Database ──────────────────────────────────────────
POSTGRES_USER=eventhub
POSTGRES_PASSWORD=eventhub_dev
POSTGRES_DB=eventhub
DATABASE_URL=postgresql://eventhub:eventhub_dev@postgres:5432/eventhub

# ── Backend ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
JWT_SECRET=change_me_in_production_min_32_chars_!!
JWT_EXPIRES_IN=7d

# ── Mail (Mailhog in dev) ─────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@eventhub.local

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
