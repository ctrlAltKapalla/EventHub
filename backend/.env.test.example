# Copy this file to .env.test and adjust values for your local setup.
# .env.test is loaded automatically by vitest — do NOT commit .env.test to git.

# Option A: native postgres (no Docker) — use the mission_control DB with a separate schema
DATABASE_URL=postgresql://mission_control:mission_control@localhost:5432/mission_control?schema=eventhub_test

# Option B: dedicated eventhub DB (Docker Compose)
# DATABASE_URL=postgresql://eventhub:eventhub_dev@localhost:5432/eventhub_test

JWT_SECRET=test_secret_at_least_32_chars_long_for_vitest
NODE_ENV=test
