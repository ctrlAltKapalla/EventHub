# Backend API base URL (no trailing slash)
# Development (docker compose): http://localhost:4000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Set to "true" to use mock data instead of real API (for local dev without backend)
# All mock data is in src/lib/mockData.ts and src/lib/mockRegistrations.ts
NEXT_PUBLIC_USE_MOCK=true
